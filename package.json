{
	"name": "awwesome",
	"description": "Enhanced user interface for Awesome Selfhosted",
	"version": "0.7.9",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"lint": "eslint src/",
		"format": "prettier --plugin-search-dir . --write .",
		"seed": "tsx scripts/seed.ts",
		"backfill-stars": "tsx scripts/backfill-stars.ts",
		"docker:build": "docker buildx build --push --platform linux/amd64,linux/arm64 --tag mkitzmann/awwesome:latest --tag mkitzmann/awwesome:0.7.9 ."
	},
	"devDependencies": {
		"@dimfeld/svelte-lazyload": "^0.0.4",
		"@sindresorhus/slugify": "^2.2.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/js-yaml": "^4.0.9",
		"@types/node-cron": "^3.0.11",
		"@types/numeral": "^2.0.2",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"autoprefixer": "^10.4.14",
		"dayjs": "^1.11.9",
		"drizzle-kit": "^0.31.8",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^3.15.2",
		"numeral": "^2.0.6",
		"postcss": "^8.4.24",
		"postcss-load-config": "^4.0.1",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.0",
		"svelte-check": "^4.3.5",
		"svelte-seo": "^2.0.0",
		"tailwindcss": "^3.3.2",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^8.0.0",
		"vitest": "^3.0.0"
	},
	"type": "module",
	"dependencies": {
		"@internationalized/date": "^3.12.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"better-sqlite3": "^12.6.2",
		"bits-ui": "^2.16.3",
		"drizzle-orm": "^0.45.1",
		"js-yaml": "^4.1.1",
		"node-cron": "^4.2.1",
		"tsx": "^4.21.0"
	}
}
